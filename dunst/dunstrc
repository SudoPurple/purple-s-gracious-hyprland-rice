[global]
    # Font & Typography
    font = JetBrains Mono 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false

    # Geometry & Position
    width = (250, 400)
    height = 200
    origin = top-right
    offset = 15x15
    scale = 0

    # Appearance & Padding
    notification_limit = 5
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 12
    horizontal_padding = 14
    text_icon_padding = 10
    frame_width = 2
    separator_color = auto

    sort = yes
    idle_threshold = 120

    # Rounded Corners
    corner_radius = 12
    corners = all

    # Icons
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    icon_path = /usr/share/icons/Papirus/16x16/status/:/usr/share/icons/Papirus/16x16/devices/

    # History & Mouse Actions
    history_length = 20
    sticky_history = yes
    history_ignore = no
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

# === MATUGEN DUNST START ===
[global]
frame_color = "#b2d189"
separator_color = "#8f9285"
highlight = "#b2d189"
progress_bar = true
progress_bar_frame_width = 1
progress_bar_height = 8
progress_bar_frame_color = "#8f9285"
progress_bar_min_width = 100
progress_bar_max_width = 300

[urgency_low]
background = "#12140e"
