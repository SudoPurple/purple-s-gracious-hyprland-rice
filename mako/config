# Mako notification daemon configuration
# Managed dynamically by wallpaper.sh (Matugen)

font=JetBrains Mono 10
width=360
height=150
margin=15
padding=12
border-size=2
border-radius=12
default-timeout=5000
anchor=top-right
max-visible=5
sort=-time
icons=1
max-icon-size=64

# === MATUGEN MAKO START ===
background-color=#1a1110e6
text-color=#f1dedc
border-color=#ffb3ad
progress-color=over #ffb3ad

[urgency=low]
background-color=#1a1110e6
text-color=#f1dedc
border-color=#a08c8a

[urgency=normal]
background-color=#1a1110e6
text-color=#f1dedc
border-color=#ffb3ad

[urgency=high]
background-color=#ffb4abe6
text-color=#571e1b
border-color=#ffb4ab
# === MATUGEN MAKO END ===
