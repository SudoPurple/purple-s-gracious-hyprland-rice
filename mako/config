# Mako notification daemon configuration
# Managed dynamically by wallpaper.sh (Matugen)

font=JetBrains Mono 10
width=360
height=150
margin=15
padding=12
border-size=2
border-radius=12
default-timeout=5000
anchor=top-right
max-visible=5
sort=-time
icons=1
max-icon-size=64

# === MATUGEN MAKO START ===
background-color=#191114d9
text-color=#efdfe2
border-color=#ffb0ca
progress-color=over #ffb0ca

[urgency=low]
background-color=#191114d9
text-color=#efdfe2
border-color=#9e8c91

[urgency=normal]
background-color=#191114d9
text-color=#efdfe2
border-color=#ffb0ca

[urgency=high]
background-color=#ffb4abd9
text-color=#541d34
border-color=#ffb4ab
# === MATUGEN MAKO END ===
