{


    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}",
        "on-click": "hyprctl dispatch 'hl.dsp.focus({ workspace = {name} })'",
        "on-scroll-up": "hyprctl dispatch 'hl.dsp.focus({ workspace = \"+1\" })'",
        "on-scroll-down": "hyprctl dispatch 'hl.dsp.focus({ workspace = \"-1\" })'"
    },

    "hyprland/window":{
        "format": " ¯¡┐  {}"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "max-volume": 150,
        "scroll-step": 5,
        "format-muted": "´Ü®",
        "format-icons": {
            "default": ["´ÇĞ", "´Çğ", "´Ç¿"]
        },
        "on-click": "pavucontrol"
    },


    "network": {
        "format-wifi": "´ç½" ,
        "tooltip": true,
        "tooltip-format": "SSID: {essid}\nSignal: {signalStrength}%\nSpeed: {bandwidthDownBits} Ôåô / {bandwidthUpBits} Ôåæ",
        "format-ethernet": "´Şû",
        "format-disconnected": "ÔÜá",
        "interval": 2,
        "on-click": "networkmanager_dmenu"
    },

    "custom/sysmon": {
        "format": "¾░¬½ ",
        "tooltip": true,
        "tooltip-format": "{}",
        "exec": "~/.config/waybar/scripts/sysmon.sh",
        "interval": 2
    },



    "cpu": {
        "format": "",
        "tooltip": false
    },

    "memory": {
        "format": "",
        "tooltip": false
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "´âğ {capacity}%",
        "format-plugged": "´çĞ {capacity}%",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
        

        "on-click": "~/.config/waybar/scripts/power-profiles.sh"
    },

    "clock": {
        "format": "´Çù {:%I:%M %p   ´ü│ %e %B}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

"custom/cava": {
  "exec": "~/.config/waybar/scripts/cava-waybar.sh",
  "return-type": "json",
  "tooltip": false,
  "restart-interval": 1
},

    "hyprland/language": {
