{


    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}",
        "on-click": "hyprctl dispatch 'hl.dsp.focus({ workspace = {name} })'",
        "on-scroll-up": "hyprctl dispatch 'hl.dsp.focus({ workspace = \"+1\" })'",
        "on-scroll-down": "hyprctl dispatch 'hl.dsp.focus({ workspace = \"-1\" })'"
    },

    "hyprland/window":{
        "format": "   {}"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "max-volume": 150,
        "scroll-step": 5,
        "format-muted": "",
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },


    "network": {
        "format-wifi": "" ,
        "tooltip": true,
        "tooltip-format": "SSID: {essid}\nSignal: {signalStrength}%\nSpeed: {bandwidthDownBits} ↓ / {bandwidthUpBits} ↑",
        "format-ethernet": "",
        "format-disconnected": "⚠",
        "interval": 2,
        "on-click": "networkmanager_dmenu"
    },

    "custom/sysmon": {
        "format": "󰪫 ",
        "tooltip": true,
        "tooltip-format": "{}",
        "exec": "~/.config/waybar/scripts/sysmon.sh",
        "interval": 2
    },



    "cpu": {
        "format": "",
        "tooltip": false
    },

    "memory": {
        "format": "",
        "tooltip": false
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-icons": ["", "", "", "", ""],
        

        "on-click": "~/.config/waybar/scripts/power-profiles.sh"
    },

    "clock": {
        "format": " {:%I:%M %p    %e %B}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

"custom/cava": {
  "exec": "~/.config/waybar/scripts/cava-waybar.sh",
  "return-type": "json",
  "tooltip": false,
  "restart-interval": 1
},

    "hyprland/language": {
        "format": "󰌌 {}",
        "format-English (US)": "EN",
        "format-Persian": "FA",
        "format-en": "EN",
        "format-ir": "FA",
        "keyboard-name": "at-translated-set-2-keyboard",
        "on-click": "hyprctl switchxkblayout at-translated-set-2-keyboard next"
    },

    "custom/power": {
        "format": "",
        "tooltip": false,
        "on-click": "wifi-manager --toggle"
    }
}
